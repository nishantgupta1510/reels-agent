# --- LLM (script generation) ---
# Groq (free tier): https://console.groq.com  -> base_url https://api.groq.com/openai/v1
# Google Gemini (free tier): https://aistudio.google.com
LLM_API_KEY=your_key_here
LLM_BASE_URL=https://api.groq.com/openai/v1
LLM_MODEL=llama-3.3-70b-versatile

# --- Visuals ---
# https://www.pexels.com/api  (free, instant)
PEXELS_API_KEY=your_key_here

# --- Telegram review gate ---
# Create bot via @BotFather, then message it once to get your chat id
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here

# --- YouTube ---
# Needs client_secret.json in project root (from Google Cloud Console)
YOUTUBE_CHANNEL_TITLE=My Channel

# --- Instagram (Graph API) ---
IG_BUSINESS_ACCOUNT_ID=your_ig_business_id
IG_ACCESS_TOKEN=your_long_lived_token

# --- Content settings ---
NICHE=interesting science facts
VIDEO_LENGTH_SECONDS=30
